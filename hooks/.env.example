# ============================================================================
# Claude Code Auto-Commit Environment Variable Configuration
# ============================================================================
# Copy this file to ~/.bashrc or ~/.zshrc
# Or create ~/.claude/.env and source it from your shell config
# ============================================================================

# ============================================================================
# GitHub Auto-Create Repository Configuration
# ============================================================================

# Auto-create GitHub repository
# Valid values: true | false | ask (default)
export CLAUDE_AUTO_CREATE_REPO=true

# Default repository visibility
# Valid values: public | private (default)
export CLAUDE_DEFAULT_REPO_VISIBILITY=private

# ============================================================================
# Git Configuration
# ============================================================================

# Git username (if not globally configured)
# export GIT_AUTHOR_NAME="Your Name"
# export GIT_COMMITTER_NAME="Your Name"

# Git email (if not globally configured)
# export GIT_AUTHOR_EMAIL="your.email@example.com"
# export GIT_COMMITTER_EMAIL="your.email@example.com"

# ============================================================================
# Commit Behavior Configuration
# ============================================================================

# Whether to auto-push (true/false)
# Note: this feature requires implementation in auto-commit.sh
export CLAUDE_AUTO_PUSH=true

# Whether to run tests before committing (true/false)
# Note: this feature requires implementation in auto-commit.sh
export CLAUDE_RUN_TESTS_BEFORE_COMMIT=false

# Whether to auto-format code before committing (true/false)
# Note: this feature requires implementation in the PostToolUse hook
export CLAUDE_AUTO_FORMAT=true

# ============================================================================
# Debug Options
# ============================================================================

# Enable verbose output
export CLAUDE_HOOKS_VERBOSE=false

# Enable dry-run mode (do not actually execute Git commands)
export CLAUDE_HOOKS_DRY_RUN=false

# ============================================================================
# Example: add to ~/.bashrc or ~/.zshrc
# ============================================================================
#
# # Claude Code auto-commit configuration
# export CLAUDE_AUTO_CREATE_REPO=true
# export CLAUDE_AUTO_PUSH=true
#
# # Optional: create a dedicated config file
# if [ -f ~/.claude/.env ]; then
#   source ~/.claude/.env
# fi
#
# ============================================================================
